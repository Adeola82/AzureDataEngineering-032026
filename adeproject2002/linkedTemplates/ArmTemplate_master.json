{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adeproject2002"
		},
		"ADLS_LS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS_LS'"
		},
		"AzureSqlDB_LS_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDB_LS'"
		},
		"ADLS_LS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adeola0220adls.dfs.core.windows.net/"
		},
		"AzureSqlDB_LS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adeproject2002server.database.windows.net"
		},
		"AzureSqlDB_LS_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adeproject2002db"
		},
		"AzureSqlDB_LS_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adeolao"
		},
		"REST_LS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://restcountries.com/v3.1/all?fields=name,capital,cca2"
		},
		"RestService_LS2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://restcountries.com/v3.1/name"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adeproject2002_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ADLS_LS_accountKey": {
						"value": "[parameters('ADLS_LS_accountKey')]"
					},
					"AzureSqlDB_LS_password": {
						"value": "[parameters('AzureSqlDB_LS_password')]"
					},
					"ADLS_LS_properties_typeProperties_url": {
						"value": "[parameters('ADLS_LS_properties_typeProperties_url')]"
					},
					"AzureSqlDB_LS_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDB_LS_properties_typeProperties_server')]"
					},
					"AzureSqlDB_LS_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDB_LS_properties_typeProperties_database')]"
					},
					"AzureSqlDB_LS_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDB_LS_properties_typeProperties_userName')]"
					},
					"REST_LS_properties_typeProperties_url": {
						"value": "[parameters('REST_LS_properties_typeProperties_url')]"
					},
					"RestService_LS2_properties_typeProperties_url": {
						"value": "[parameters('RestService_LS2_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adeproject2002_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adeproject2002_ArmTemplate_0')]"
			]
		},
		{
			"name": "adeproject2002_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adeproject2002_ArmTemplate_1')]"
			]
		},
		{
			"name": "adeproject2002_ArmTemplate_3",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_3.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adeproject2002_ArmTemplate_2')]"
			]
		},
		{
			"name": "adeproject2002_ArmTemplate_4",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_4.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adeproject2002_ArmTemplate_3')]"
			]
		}
	]
}